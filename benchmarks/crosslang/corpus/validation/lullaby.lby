# Cross-language validation suite (Lullaby). Real-world validators: checksums,
# calendar/date rules, character classes, and range checks. Arrays carry their
# length, so array validators iterate with `for x in a`; strings are walked with
# `for c in s` / `s[i]`. Boolean 1/0 results use the inline conditional
# `A if C else B`. `is_digit` is ASCII; hex/case checks keep explicit code
# ranges to stay ASCII-strict. See ../../SPEC.md.

fn luhn_check digits array<i64>
    let n = len(digits)
    let sum = 0
    for i from 0 to n - 1
        let d = digits[i]
        let pos = n - 1 - i
        if pos % 2 == 1
            d = d * 2
            if d > 9
                d = d - 9
        sum += d
    1 if sum % 10 == 0 else 0

fn is_valid_isbn10 digits array<i64>
    if len(digits) != 10
        return 0
    let sum = 0
    for i from 0 to 9
        sum += (10 - i) * digits[i]
    1 if sum % 11 == 0 else 0

fn in_range x i64 lo i64 hi i64
    1 if x >= lo and x <= hi else 0

fn is_leap_year y i64
    1 if y % 400 == 0 else 0 if y % 100 == 0 else 1 if y % 4 == 0 else 0

fn is_valid_month m i64
    1 if m >= 1 and m <= 12 else 0

fn days_in_month y i64 m i64
    if m == 2
        return 29 if is_leap_year(y) == 1 else 28
    if m == 4 or m == 6 or m == 9 or m == 11
        return 30
    if m >= 1 and m <= 12
        return 31
    0

fn is_valid_day y i64 m i64 d i64
    if is_valid_month(m) == 0
        return 0
    if d < 1 or d > days_in_month(y, m)
        return 0
    1

fn is_ascii_digit c string
    1 if is_digit(c[0]) else 0

fn is_ascii_alpha c string
    let code = char_code(c[0])
    1 if (code >= 65 and code <= 90) or (code >= 97 and code <= 122) else 0

fn all_digits s string
    if len(s) == 0
        return 0
    for c in s
        if not is_digit(c)
            return 0
    1

fn password_score s string
    let score = 0
    if len(s) >= 8
        score += 1
    let has_digit = 0
    let has_lower = 0
    let has_upper = 0
    for c in s
        let code = char_code(c)
        if code >= 48 and code <= 57
            has_digit = 1
        elif code >= 97 and code <= 122
            has_lower = 1
        elif code >= 65 and code <= 90
            has_upper = 1
    score + has_digit + has_lower + has_upper

fn is_hex_string s string
    if len(s) == 0
        return 0
    for c in s
        let code = char_code(c)
        if not ((code >= 48 and code <= 57) or (code >= 97 and code <= 102) or (code >= 65 and code <= 70))
            return 0
    1

fn checksum_mod10 digits array<i64>
    let sum = 0
    for d in digits
        sum += d
    sum % 10

fn valid_percentage x i64
    1 if x >= 0 and x <= 100 else 0

fn is_valid_rgb r i64 g i64 b i64
    1 if r >= 0 and r <= 255 and g >= 0 and g <= 255 and b >= 0 and b <= 255 else 0

fn even_parity bits array<i64>
    let ones = 0
    for b in bits
        ones += 1 if b == 1 else 0
    1 if ones % 2 == 0 else 0

fn main
    let card array<i64> = [7, 9, 9, 2, 7, 3, 9, 8, 7, 1, 3]
    let isbn array<i64> = [0, 3, 0, 6, 4, 0, 6, 1, 5, 2]
    let bits array<i64> = [1, 0, 1, 1, 0, 0]
    println("luhn=" + to_string(luhn_check(card)))
    println("isbn=" + to_string(is_valid_isbn10(isbn)))
    println("in_range=" + to_string(in_range(5, 1, 10)))
    println("leap=" + to_string(is_leap_year(2000)))
    println("month=" + to_string(is_valid_month(13)))
    println("day=" + to_string(is_valid_day(2021, 2, 29)))
    println("digit=" + to_string(is_ascii_digit("7")))
    println("alpha=" + to_string(is_ascii_alpha("Q")))
    println("all_digits=" + to_string(all_digits("12345")))
    println("pw=" + to_string(password_score("Abcdef12")))
    println("hex=" + to_string(is_hex_string("1aF")))
    println("csum=" + to_string(checksum_mod10(card)))
    println("pct=" + to_string(valid_percentage(101)))
    println("rgb=" + to_string(is_valid_rgb(255, 128, 0)))
    println("parity=" + to_string(even_parity(bits)))
