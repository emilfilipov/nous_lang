# Cross-language validation suite (Lullaby). Real-world validators: checksums,
# calendar/date rules, character classes, and range checks. See ../../SPEC.md.
# Lullaby has no `%` operator; `rem` is truncating remainder (matches C's `%`).
# 1-char string args carry a single ASCII character; strings have no ordering
# comparison, so character classes go through `char_code`.

fn luhn_check digits array<i64> n i64 -> i64
    let sum = 0
    for i from 0 to n - 1
        let d = digits[i]
        let pos = n - 1 - i
        if pos % 2 == 1
            d = d * 2
            if d > 9
                d = d - 9
        sum += d
    if sum % 10 == 0
        1
    else
        0

fn is_valid_isbn10 digits array<i64> n i64 -> i64
    if n != 10
        return 0
    let sum = 0
    for i from 0 to 9
        sum += (10 - i) * digits[i]
    if sum % 11 == 0
        1
    else
        0

fn in_range x i64 lo i64 hi i64 -> i64
    if x >= lo and x <= hi
        1
    else
        0

fn is_leap_year y i64 -> i64
    if y % 400 == 0
        return 1
    if y % 100 == 0
        return 0
    if y % 4 == 0
        return 1
    0

fn is_valid_month m i64 -> i64
    if m >= 1 and m <= 12
        1
    else
        0

fn days_in_month y i64 m i64 -> i64
    if m == 2
        if is_leap_year(y) == 1
            return 29
        return 28
    if m == 4 or m == 6 or m == 9 or m == 11
        return 30
    if m >= 1 and m <= 12
        return 31
    0

fn is_valid_day y i64 m i64 d i64 -> i64
    if is_valid_month(m) == 0
        return 0
    if d < 1 or d > days_in_month(y, m)
        return 0
    1

fn is_ascii_digit c string -> i64
    let code = char_code(get(chars(c), 0))
    if code >= 48 and code <= 57
        1
    else
        0

fn is_ascii_alpha c string -> i64
    let code = char_code(get(chars(c), 0))
    if (code >= 65 and code <= 90) or (code >= 97 and code <= 122)
        1
    else
        0

fn all_digits s string -> i64
    let cs list<char> = chars(s)
    let n = len(cs)
    if n == 0
        return 0
    for i from 0 to n - 1
        let code = char_code(get(cs, i))
        if code < 48 or code > 57
            return 0
    1

fn password_score s string -> i64
    let cs list<char> = chars(s)
    let n = len(cs)
    let score = 0
    if n >= 8
        score += 1
    let has_digit = 0
    let has_lower = 0
    let has_upper = 0
    for i from 0 to n - 1
        let code = char_code(get(cs, i))
        if code >= 48 and code <= 57
            has_digit = 1
        elif code >= 97 and code <= 122
            has_lower = 1
        elif code >= 65 and code <= 90
            has_upper = 1
    score + has_digit + has_lower + has_upper

fn is_hex_string s string -> i64
    let cs list<char> = chars(s)
    let n = len(cs)
    if n == 0
        return 0
    for i from 0 to n - 1
        let code = char_code(get(cs, i))
        let ok = 0
        if code >= 48 and code <= 57
            ok = 1
        if code >= 97 and code <= 102
            ok = 1
        if code >= 65 and code <= 70
            ok = 1
        if ok == 0
            return 0
    1

fn checksum_mod10 digits array<i64> n i64 -> i64
    let sum = 0
    for i from 0 to n - 1
        sum += digits[i]
    sum % 10

fn valid_percentage x i64 -> i64
    if x >= 0 and x <= 100
        1
    else
        0

fn is_valid_rgb r i64 g i64 b i64 -> i64
    if r >= 0 and r <= 255 and g >= 0 and g <= 255 and b >= 0 and b <= 255
        1
    else
        0

fn even_parity bits array<i64> n i64 -> i64
    let ones = 0
    for i from 0 to n - 1
        if bits[i] == 1
            ones += 1
    if ones % 2 == 0
        1
    else
        0

fn main -> void
    let card array<i64> = [7, 9, 9, 2, 7, 3, 9, 8, 7, 1, 3]
    let isbn array<i64> = [0, 3, 0, 6, 4, 0, 6, 1, 5, 2]
    let bits array<i64> = [1, 0, 1, 1, 0, 0]
    println("luhn=" + to_string(luhn_check(card, 11)))
    println("isbn=" + to_string(is_valid_isbn10(isbn, 10)))
    println("in_range=" + to_string(in_range(5, 1, 10)))
    println("leap=" + to_string(is_leap_year(2000)))
    println("month=" + to_string(is_valid_month(13)))
    println("day=" + to_string(is_valid_day(2021, 2, 29)))
    println("digit=" + to_string(is_ascii_digit("7")))
    println("alpha=" + to_string(is_ascii_alpha("Q")))
    println("all_digits=" + to_string(all_digits("12345")))
    println("pw=" + to_string(password_score("Abcdef12")))
    println("hex=" + to_string(is_hex_string("1aF")))
    println("csum=" + to_string(checksum_mod10(card, 11)))
    println("pct=" + to_string(valid_percentage(101)))
    println("rgb=" + to_string(is_valid_rgb(255, 128, 0)))
    println("parity=" + to_string(even_parity(bits, 6)))
