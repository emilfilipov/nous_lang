# Build outputs
target/
dist/
build/
out/

# Rust/editor tooling
*.pdb
*.rlib

# Compiler output. `lullaby native <file>` with no `-o` writes the binary beside
# its source, so a bare invocation in the tree drops an artifact next to the
# fixture it compiled. Six were committed that way before this rule existed.
*.exe

# Local caches and temporary files
.cache/
.tmp/
tmp/
*.tmp
*.log

# Agent tooling worktrees and local state
.claude/

# Editor and OS state
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
Desktop.ini

# Test artifacts
coverage/
test-results/

crates/lullaby_wasm/pkg/
crates/lullaby_wasm/target/

# Native/C/C++ benchmark build artifacts
*.obj

# Python bytecode cache (benchmark/tooling scripts)
__pycache__/
*.pyc
