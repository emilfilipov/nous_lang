# Test-runner fixture: a test that RUNS AWAY IN RECURSION must not kill the run.
# `test_b_overflows` recurses without a base case. This USED to fault on the guard
# page and terminate the process running it (not a runtime error, so the
# interpreter's `Result` never saw it). The interpreters now bound recursion
# uniformly (L0466, crates/lullaby_runtime/src/interp_stack.rs), so it ends with a
# clean, catchable recursion-limit diagnostic instead.
#
# Either way the runner isolates the suite in a child process: the parent reports
# `test_b_overflows` as a failure (now naming the recursion limit), resumes the
# batch at the next test, and still summarizes `3 passed, 1 failed`.
#
# This fixture lives under `tests/fixtures/test_runner/` (not `valid/`) so the
# top-level fixture harness does not sweep it onto every backend: it has no
# `main` and is meant to FAIL, by design.

fn recurse_forever n i64 -> i64
    # No base case: each frame recurses deeper until the shared recursion bound
    # (INTERPRETER_RECURSION_LIMIT) stops it with L0466.
    recurse_forever(n + 1)

fn test_a_passes -> void
    assert(1 + 1 == 2)

fn test_b_overflows -> void
    let bad i64 = recurse_forever(0)
    assert(bad == 0)

fn test_c_passes -> void
    assert(2 + 2 == 4)

fn test_d_passes -> void
    assert(3 + 3 == 6)
