fn check f f64 want f64 -> i64
    if f == want
        1
    else
        0

fn main -> i64
    let ia i64 = abs(0 - 5)
    let imn i64 = min(3, 7)
    let imx i64 = max(3, 7)
    let ip i64 = pow(2, 10)
    let int_total i64 = ia + imn + imx + ip

    let fa i64 = check(abs(0.0 - 2.5), 2.5)
    let fmn i64 = check(min(1.5, 2.5), 1.5)
    let fmx i64 = check(max(1.5, 2.5), 2.5)
    let fp i64 = check(pow(2.0, 3.0), 8.0)
    let fs i64 = check(sqrt(16.0), 4.0)
    let ff i64 = check(floor(2.7), 2.0)
    let fc i64 = check(ceil(2.1), 3.0)
    let fr i64 = check(round(2.5), 3.0)
    let float_checks i64 = fa + fmn + fmx + fp + fs + ff + fc + fr

    int_total + float_checks
