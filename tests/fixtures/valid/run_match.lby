enum Shape
    Circle i64
    Rect i64 i64
    Empty

enum Color
    Red
    Green
    Blue

fn area s Shape -> i64
    match s
        Circle(r) -> r * r
        Rect(w, h) -> w * h
        Empty -> 0

fn rank c Color -> i64
    match c
        Green -> 10
        _ -> 1

fn main -> i64
    let circle Shape = Circle(3)
    let rect Shape = Rect(4, 5)
    let hole Shape = Empty
    let total i64 = area(circle) + area(rect) + area(hole)
    total + rank(Green) + rank(Red)
