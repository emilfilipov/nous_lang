fn random_len n i64 -> i64
    match os_random(n)
        ok(bytes) -> len(bytes)
        err(_) -> 0 - 1

fn main -> i64
    # `os_random` returns real OS-CSPRNG bytes, so the raw bytes are
    # non-deterministic. This fixture only checks structural, backend-invariant
    # facts so the AST/IR/bytecode (and optimized) backends all agree.

    # A 16-byte request yields exactly 16 bytes: contributes 1.
    let sixteen i64 = random_len(16)
    let got_sixteen i64 = 0
    if sixteen == 16
        got_sixteen = 1

    # A 0-byte request yields an empty list (no error): contributes 1.
    let zero i64 = random_len(0)
    let got_zero i64 = 0
    if zero == 0
        got_zero = 1

    # A negative length must NOT panic; it yields `err`, so `random_len`
    # returns -1: contributes 0 and proves the total, non-panicking behavior.
    let negative i64 = random_len(0 - 1)
    let got_negative i64 = 0
    if negative == 0 - 1
        got_negative = 1

    # Deterministic result: 1 + 1 + 1 = 3 on every backend.
    got_sixteen + got_zero + got_negative
