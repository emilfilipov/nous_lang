# Stage-1 user-defined generic structs: single scalar type parameter `T`.
# Exercises two distinct instantiations of `Box<T>` (`Box<i64>` and `Box<bool>`),
# a second generic struct `Pair<T>`, construction (positional and named), field
# read with `T` substituted to the concrete type, value-semantic copy, and
# passing/returning a generic value through functions. The result is identical on
# every interpreter backend (ast / ir / bytecode).

struct Box<T>
    value T

struct Pair<T>
    first T
    second T

fn unbox b Box<i64> -> i64
    b.value

# Takes a generic value by value and returns a fresh one; the caller's argument
# is unchanged (value semantics).
fn rewrap b Box<i64> -> Box<i64>
    Box(b.value + 1)

fn pair_sum p Pair<i64> -> i64
    p.first + p.second

fn main -> i64
    let a Box<i64> = Box(5)
    let flag Box<bool> = Box(true)
    let copy Box<i64> = a
    let bumped Box<i64> = rewrap(a)
    let p Pair<i64> = Pair(first: 10, second: 20)
    let extra i64 = 100 if flag.value else 0
    # unbox(a)=5 proves `a` survived `rewrap` unchanged (value semantics).
    unbox(a) + unbox(copy) + unbox(bumped) + pair_sum(p) + extra
