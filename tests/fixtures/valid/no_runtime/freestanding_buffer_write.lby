# A WRITE-THROUGH buffer walk in the freestanding (`no-runtime`) tier: walk a
# pointer forward with `ptr_offset` and `ptr_write` each cell, then read the
# buffer back through ordinary indexing to prove the stores genuinely aliased it.
#
# Every tier defines this program and they all agree (105). Native `addr_of` is a
# real `lea`; the interpreters' `addr_of` is place-backed, so an in-frame store
# aliases the original buffer there too. `L0459` refuses only a pointer used
# outside the frame that owns its place — which this program never does, since the
# pointer never leaves `fill_and_sum`/`poke_at`.
no-runtime

# Fill a buffer by walking a write pointer forward, then sum it back by index.
# If the layout descended, `ptr_offset(p, +k)` would write BACKWARDS off the
# front of the buffer and this would corrupt the frame instead of filling `buf`.
fn fill_and_sum -> i64
    let buf array<i64> = [0, 0, 0, 0]
    unsafe
        let p ptr<i64> = addr_of(buf[0])
        ptr_write(p, 1)
        ptr_write(ptr_offset(p, 1), 2)
        ptr_write(ptr_offset(p, 2), 4)
        ptr_write(ptr_offset(p, 3), 8)
    buf[0] + buf[1] + buf[2] + buf[3]

# A write through a pointer taken at a RUNTIME index, read back by index.
fn poke_at n i64 -> i64
    let buf array<i64> = [0, 0, 0]
    unsafe
        ptr_write(addr_of(buf[n]), 90)
    buf[0] + buf[1] + buf[2]

fn main -> i64
    # 15 + 90 = 105
    fill_and_sum() + poke_at(1)
