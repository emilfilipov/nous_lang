# Scalar math builtins on the WASM backend, at parity with the native backend
# and bit-for-bit with the interpreters. The `i64` suite (`abs`/`min`/`max`/`gcd`/
# `sign`/`clamp`) lowers to inline branchless opcode sequences; `sqrt`/`abs` on
# `f64` lower to `f64.sqrt`/`f64.abs`. The `f64` cases of `min`/`max`/`sign`/
# `clamp` are DEFERRED (they run on the interpreters), so none appear here.
# `main` returns a deterministic i64 across AST/IR/bytecode and WASM.

# The signed 64-bit minimum, -9223372036854775808 (can't be negated naively).
fn imin -> i64
    0 - 9223372036854775807 - 1

# f64 `sqrt`/`abs` folded to i64 via exact comparisons (perfect squares and
# representable magnitudes are exact under IEEE-754 round-to-nearest, so every
# backend agrees). Each passing check contributes 1.
fn f64_checks -> i64
    let n i64 = 0
    if sqrt(16.0) == 4.0
        n += 1
    if sqrt(0.0) == 0.0
        n += 1
    if sqrt(2.0) > 1.4142135 and sqrt(2.0) < 1.4142136
        n += 1
    if abs(0.0 - 3.5) == 3.5
        n += 1
    if abs(3.5) == 3.5
        n += 1
    return n

# The `i64::MIN` edge case for `gcd`: `gcd(i64::MIN, 0)` is `i64::MIN` (its own
# unsigned magnitude 2^63 reinterpreted). Holds on every backend.
#
# (`abs(i64::MIN)` also wraps to `i64::MIN` on the WASM/native backends, but the
# interpreters' ground-truth `i64::abs` panics on that single input under a
# debug/overflow-checked build, so it is exercised only by the structural encoder
# test `f64_sqrt_and_abs_emit_their_opcodes` + direct node runs, not folded here.)
fn edge_checks -> i64
    let n i64 = 0
    if gcd(imin(), 0) == imin()
        n += 1
    return n

fn main -> i64
    let s i64 = 0
    # abs(i64)
    s += abs(0 - 5)             # 5
    s += abs(8)                # 8
    # min / max (i64)
    s += min(3, 7)             # 3
    s += max(3, 7)             # 7
    s += min(0 - 4, 0 - 9)     # -9
    s += max(0 - 4, 0 - 9)     # -4
    # gcd (i64)
    s += gcd(12, 18)           # 6
    s += gcd(0 - 12, 18)       # 6
    s += gcd(0, 5)             # 5
    s += gcd(48, 36)           # 12
    # sign (i64)
    s += sign(0 - 42)          # -1
    s += sign(42)              # 1
    s += sign(0)               # 0
    # clamp (i64), including lo > hi (yields lo)
    s += clamp(15, 0, 10)      # 10
    s += clamp(0 - 3, 0, 10)   # 0
    s += clamp(5, 0, 10)       # 5
    s += clamp(5, 10, 0)       # 10
    # f64 sqrt/abs and i64::MIN edges, folded to small counts
    s += f64_checks()          # 5
    s += edge_checks()         # 1
    return s
