# The pointer size law across several pointee types:
#   ptr_to_int(ptr_offset(p, 1)) - ptr_to_int(p) == size_of(T)
# and a NEGATIVE offset walking back (`ptr_offset(p, -3)` == p - 3*8).
#
# 8 (i64) + 4 (i32) + 2 (i16) + 1 (byte) + 8 (ptr<i64>) + 24 (the -3 walk) = 47.
#
# Native-only: `int_to_ptr` of a bare address is not a valid heap-slot handle on
# the interpreters (L0406); native treats it as the real machine address it is.
fn main -> i64
    unsafe
        let p8 ptr<i64> = int_to_ptr(4096)
        let p4 ptr<i32> = int_to_ptr(4096)
        let p2 ptr<i16> = int_to_ptr(4096)
        let p1 ptr<byte> = int_to_ptr(4096)
        let pp ptr<ptr<i64>> = int_to_ptr(4096)
        let s8 i64 = ptr_to_int(ptr_offset(p8, 1)) - ptr_to_int(p8)
        let s4 i64 = ptr_to_int(ptr_offset(p4, 1)) - ptr_to_int(p4)
        let s2 i64 = ptr_to_int(ptr_offset(p2, 1)) - ptr_to_int(p2)
        let s1 i64 = ptr_to_int(ptr_offset(p1, 1)) - ptr_to_int(p1)
        let sp i64 = ptr_to_int(ptr_offset(pp, 1)) - ptr_to_int(pp)
        let back i64 = ptr_to_int(p8) - ptr_to_int(ptr_offset(p8, 0 - 3))
        s8 + s4 + s2 + s1 + sp + back
